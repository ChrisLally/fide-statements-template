{
  "name": "fide.work-turbo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:api:prod": "pnpm --filter @fide.work/fcp build && pnpm --filter @fide.work/db build && pnpm --filter api build:local",
    "build:docs:prod": "pnpm --filter @fide.work/fcp build && pnpm --filter docs build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "subtree:fide-attestor-template:push": "bash scripts/subtree/fide-attestor-template-push.sh",
    "subtree:fide-attestor-template:pull": "bash scripts/subtree/fide-attestor-template-pull.sh"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.9",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
