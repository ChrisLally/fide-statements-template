{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:cf": "pnpm exec wrangler dev",
    "build": "cd ../.. && pnpm --filter @fide.work/fcp build && pnpm --filter @fide.work/db build && pnpm --filter @fide.work/graph build && pnpm --filter @fide.work/indexer build && pnpm --filter api run build:local",
    "build:api:prod": "cd ../.. && pnpm build:api:prod",
    "build:local": "tsc",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "start": "node dist/index.js",
    "deploy:cf": "pnpm exec wrangler deploy",
    "deploy:cf:dry-run": "pnpm exec wrangler deploy --dry-run"
  },
  "dependencies": {
    "@fide.work/db": "workspace:*",
    "@fide.work/fcp": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^0.18.4",
    "@supabase/supabase-js": "^2.95.3",
    "dotenv": "^16.4.7",
    "hono": "^4.11.9",
    "viem": "^2.21.48",
    "zod": "^3.24.2",
    "@fide.work/indexer": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.52.0"
  }
}
