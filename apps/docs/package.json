{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter api openapi:export && pnpm sdk:generate",
    "sdk:generate": "tsx scripts/fcp/sdks/js/generate-sdk-reference.ts",
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "docs:check": "tsx scripts/validate-links.ts",
    "build:docs:prod": "cd ../.. && pnpm build:docs:prod"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@fide.work/fcp": "workspace:*",
    "@radix-ui/react-collapsible": "^1.1.12",
