{
  "name": "fide-indexer-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FCP indexer — pull from registry → verify → materialize to Supabase",
  "scripts": {
    "index": "tsx src/scripts/index.ts",
    "index:rekor": "FCP_INDEXER_SOURCE_MODE=rekor tsx src/scripts/index.ts",
    "index:filesystem": "FCP_INDEXER_SOURCE_MODE=filesystem tsx src/scripts/index.ts",
    "index:discover": "tsx src/scripts/discover.ts",
    "schema:reset": "tsx src/scripts/migrate.ts",
    "reset": "tsx src/scripts/reset.ts"
  },
  "dependencies": {
    "@fide.work/fcp": "workspace:*",
    "@supabase/supabase-js": "^2.95.3",
    "dotenv": "^16.4.7",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.16.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
