{
  "name": "@fide.work/indexer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "mock:webhook": "pnpm run build && node dist/scripts/mock-webhook.js"
  },
  "dependencies": {
    "@fide.work/fcp": "workspace:*",
    "@fide.work/graph": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "typescript": "^5.8.3"
  }
}
